{
  "name": "kraken",
  "productName": "Kraken",
  "description": "Self-hosted voice and text chat",
  "main": "electron/dist/main.cjs",
  "private": true,
  "license": "AGPL-3.0-only",
  "version": "0.0.1",
  "author": {
    "name": "Kraken Team",
    "email": "noreply@krakenchat.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/krakenchat/kraken.git"
  },
  "type": "module",
  "scripts": {
    "clean": "rimraf dist electron/dist release",
    "build": "vite build",
    "build-electron": "tsc --project electron/tsconfig.electron.json && mv electron/dist/main.js electron/dist/main.cjs",
    "build-preload": "tsc electron/preload.ts --outDir electron/dist --module commonjs --target es2020 --esModuleInterop --skipLibCheck && mv electron/dist/preload.js electron/dist/preload.cjs",
    "build:all": "pnpm run clean && pnpm run build && pnpm run build-electron && pnpm run build-preload",
    "build:renderer": "vite build",
    "package": "pnpm run build:all && electron-builder --dir",
    "build:win": "pnpm run build:all && electron-builder --win",
    "build:mac": "pnpm run build:all && electron-builder --mac",
    "build:linux": "pnpm run build:all && electron-builder --linux",
    "build:linux:appimage": "pnpm run build:all && electron-builder --linux AppImage",
    "build:linux:deb": "pnpm run build:all && electron-builder --linux deb",
    "build:linux:rpm": "pnpm run build:all && electron-builder --linux rpm",
    "build:all-platforms": "pnpm run build:all && electron-builder --win --linux --mac",
    "release": "pnpm run build:all && electron-builder --publish always",
    "docker:build:win": "docker run --rm -v \"$(pwd)\":/project -v ~/.cache/electron:/root/.cache/electron -v ~/.cache/electron-builder:/root/.cache/electron-builder -w /project electronuserland/builder:wine /bin/bash -c 'pnpm install --frozen-lockfile && pnpm run build:win'",
    "docker:build:linux": "docker run --rm -v \"$(pwd)\":/project -v ~/.cache/electron:/root/.cache/electron -v ~/.cache/electron-builder:/root/.cache/electron-builder -w /project electronuserland/builder /bin/bash -c 'pnpm install --frozen-lockfile && pnpm run build:linux'",
    "dev": "vite --host 0.0.0.0",
    "start": "pnpm run build-electron && pnpm run build-preload && electron .",
    "electron-dev": "concurrently -k \"cross-env NODE_ENV=development vite\" \"wait-on http://localhost:5173 && pnpm run build-electron && pnpm run build-preload && electron .\"",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 20",
    "lint:fix": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 20 --fix",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:report": "playwright show-report",
    "test:e2e:docker": "../scripts/run-e2e.sh",
    "test:e2e:docker:all": "../scripts/run-e2e.sh --all",
    "test:e2e:docker:ui": "../scripts/run-e2e.sh --ui",
    "test:e2e:docker:clean": "../scripts/run-e2e.sh --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "generate:api": "openapi-ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.9",
    "@hey-api/client-fetch": "^0.13.1",
    "@kraken/shared": "workspace:*",
    "@livekit/components-react": "^2.9.17",
    "@mui/icons-material": "^7.0.2",
    "@mui/material": "^7.0.2",
    "@openobserve/browser-logs": "^0.2.11",
    "@openobserve/browser-rum": "^0.2.11",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "electron-audio-loopback": "^1.0.6",
    "electron-updater": "^6.3.9",
    "hls.js": "^1.6.15",
    "livekit-client": "^2.13.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.5.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@hey-api/openapi-ts": "^0.92.3",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/semver": "^7.7.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "38.8.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.0.0",
    "jsdom": "^28.0.0",
    "msw": "^2.12.10",
    "rimraf": "^6.0.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.4.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.3"
  }
}
