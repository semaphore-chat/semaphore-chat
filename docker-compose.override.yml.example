# Docker Compose Local Overrides
#
# Copy this file to `docker-compose.override.yml` to customize your local development setup.
# The override file is automatically merged with docker-compose.yml when you run docker-compose commands.
#
# Setup:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   # Edit docker-compose.override.yml with your preferred configuration
#   docker-compose up
#
# Note: docker-compose.override.yml is gitignored so your local config won't be committed.

# ==============================================================================
# EGRESS OUTPUT STORAGE OVERRIDES
# ==============================================================================
# By default, egress output is stored in a Docker named volume (`egress-data`)
# shared between the `livekit-egress` and `backend` services. This works out of
# the box — use the overrides below only if you need a different storage backend.

# ------------------------------------------------------------------------------
# Option: Local Bind Mount (inspect files on host)
# ------------------------------------------------------------------------------
# Replaces the named volume with a host directory for easy file inspection.
#
# services:
#   backend:
#     volumes:
#       - ./egress-output:/app/storage/replay-segments
#
#   livekit-egress:
#     volumes:
#       - ./egress-output:/out
#
# Notes:
#   - Directory ./egress-output will be created automatically
#   - Add ./egress-output to .gitignore if you create it

# ------------------------------------------------------------------------------
# Option: NFS Mount (production-like, shared storage)
# ------------------------------------------------------------------------------
# Use if you have an NFS server for testing production-like scenarios.
#
# services:
#   backend:
#     volumes:
#       - type: volume
#         source: egress-nfs
#         target: /app/storage/replay-segments
#
#   livekit-egress:
#     volumes:
#       - type: volume
#         source: egress-nfs
#         target: /out
#
# volumes:
#   egress-nfs:
#     driver: local
#     driver_opts:
#       type: nfs
#       o: addr=192.168.1.100,nfsvers=4,rw
#       device: ":/path/to/nfs/share/kraken-egress"

# ==============================================================================
# DYNAMIC IP WATCHER OVERRIDES
# ==============================================================================
# The livekit-ip-watcher service monitors your external IP and restarts
# LiveKit when it changes (useful for residential / dynamic-IP connections).
# Enable it with: docker compose --profile dynamic-ip up -d
#
# services:
#   livekit-ip-watcher:
#     environment:
#       - CHECK_INTERVAL=120                # Check every 2 minutes instead of 5
#       - IP_CHECK_URLS=https://api.ipify.org,https://ifconfig.me/ip

# ==============================================================================
# OTHER LOCAL OVERRIDES
# ==============================================================================
# You can override any service configuration here, for example:
#
# services:
#   backend:
#     environment:
#       - DEBUG=true
#       - LOG_LEVEL=verbose
#
#   frontend:
#     ports:
#       - "8080:5173"  # Use different port
#
#   mongo:
#     volumes:
#       - ~/mongo-data:/data/db  # Use custom data location
