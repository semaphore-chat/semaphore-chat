# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

MONGODB_URL=mongodb://mongo:27017/kraken?replicaSet=rs0&retryWrites=true&w=majority&directConnection=true
JWT_SECRET=some long elaborate secret that you really need to change
JWT_REFRESH_SECRET=a different long elaborate secret to change
REDIS_HOST=redis

# LiveKit Configuration (local dev defaults — override for external LiveKit)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret-that-is-at-least-32-characters-long
# Internal URL for server-to-server LiveKit API calls (Docker network)
LIVEKIT_INTERNAL_URL=http://livekit:7880

# Replay Buffer Configuration
REPLAY_SEGMENTS_PATH=/app/storage/replay-segments
REPLAY_EGRESS_OUTPUT_PATH=/out
REPLAY_SEGMENT_CLEANUP_AGE_MINUTES=20

# Push Notifications (Web Push / VAPID)
# Generate keys with: npx web-push generate-vapid-keys
# Each instance needs unique keys - treat like JWT secrets
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-instance.com