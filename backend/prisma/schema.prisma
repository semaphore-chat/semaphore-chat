datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  output          = "../../node_modules/.prisma/client"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["fullTextSearchPostgres"]
}

model Message {
  id                   String    @id @default(uuid())
  channelId            String? // Now optional, for DMs
  directMessageGroupId String? // New, for DMs
  authorId             String? // Nullable: shows "[Deleted User]" when author is deleted
  sentAt               DateTime  @default(now())
  editedAt             DateTime?
  deletedAt            DateTime?
  pendingAttachments   Int?      @default(0) // Count of files currently uploading
  searchText           String? // Flattened text from spans for searching

  // Pinning fields
  pinned   Boolean   @default(false)
  pinnedAt DateTime?
  pinnedBy String?

  // Moderation fields (for soft delete by mods)
  deletedBy       String? // Who deleted the message (null if author)
  deletedByReason String? // Reason for mod deletion

  // Threading fields
  parentMessageId String? // If set, this is a thread reply
  replyCount      Int       @default(0) // Number of replies (only on parent messages)
  lastReplyAt     DateTime? // When the last reply was added

  // Relations (composite types → proper tables)
  spans       MessageSpan[]
  reactions   MessageReaction[]
  attachments MessageAttachment[]

  channel            Channel?            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  directMessageGroup DirectMessageGroup? @relation("DirectMessageGroupMessages", fields: [directMessageGroupId], references: [id], onDelete: Cascade)
  author             User?               @relation("MessageAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  pinnedByUser       User?               @relation("MessagePinner", fields: [pinnedBy], references: [id], onDelete: SetNull)
  deletedByUser      User?               @relation("MessageDeleter", fields: [deletedBy], references: [id], onDelete: SetNull)
  notifications      Notification[]

  // Thread self-relation
  parentMessage Message?  @relation("ThreadReplies", fields: [parentMessageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  threadReplies Message[] @relation("ThreadReplies")

  // Thread subscribers
  threadSubscribers ThreadSubscriber[] @relation("MessageThreadSubscribers")

  // Back-references
  moderationLogs             ModerationLog[] @relation("LogTargetMessage")
  readReceipts               ReadReceipt[]   @relation("ReadReceiptLastMessage")
  parentMessageNotifications Notification[]  @relation("NotificationParentMessage")
  resourceFiles              File[]          @relation("FileResourceMessage")

  @@index([channelId, sentAt]) // Primary message loading (cursor pagination)
  @@index([channelId, authorId, sentAt]) // Slowmode check
  @@index([directMessageGroupId, sentAt]) // DM message loading (cursor pagination)
  @@index([channelId, pinned]) // For fetching pinned messages in a channel
  @@index([parentMessageId]) // For fetching thread replies
  @@index([authorId]) // Author-based lookups
}

model MessageSpan {
  id          String   @id @default(uuid())
  messageId   String
  position    Int // ordering within the message
  type        SpanType
  text        String?
  userId      String? // For USER_MENTION
  specialKind String? // For SPECIAL_MENTION: "here", "channel"
  communityId String? // For COMMUNITY_MENTION
  aliasId     String? // For ALIAS_MENTION

  message    Message?    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user       User?       @relation("SpanUser", fields: [userId], references: [id], onDelete: SetNull)
  community  Community?  @relation("SpanCommunity", fields: [communityId], references: [id], onDelete: SetNull)
  aliasGroup AliasGroup? @relation("SpanAlias", fields: [aliasId], references: [id], onDelete: SetNull)

  @@index([messageId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  emoji     String
  userId    String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("ReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, emoji, userId])
  @@index([messageId])
}

model MessageAttachment {
  id        String @id @default(uuid())
  messageId String
  fileId    String
  position  Int    @default(0)

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  file    File    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([messageId, fileId])
  @@index([messageId])
}

model ThreadSubscriber {
  id              String   @id @default(uuid())
  userId          String
  parentMessageId String
  subscribedAt    DateTime @default(now())

  user          User    @relation("UserThreadSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  parentMessage Message @relation("MessageThreadSubscribers", fields: [parentMessageId], references: [id], onDelete: Cascade)

  @@unique([userId, parentMessageId])
  @@index([parentMessageId]) // For fetching all subscribers of a thread
  @@index([userId]) // For fetching all threads a user is subscribed to
}

model ReadReceipt {
  id                   String   @id @default(uuid())
  userId               String
  channelId            String? // For channel messages
  directMessageGroupId String? // For DM messages
  lastReadMessageId    String // Watermark - last message the user has read
  lastReadAt           DateTime @default(now())

  user               User?               @relation("UserReadReceipts", fields: [userId], references: [id], onDelete: Cascade)
  channel            Channel?            @relation("ChannelReadReceipts", fields: [channelId], references: [id], onDelete: Cascade)
  directMessageGroup DirectMessageGroup? @relation("DirectMessageGroupReadReceipts", fields: [directMessageGroupId], references: [id], onDelete: Cascade)
  lastReadMessage    Message             @relation("ReadReceiptLastMessage", fields: [lastReadMessageId], references: [id], onDelete: Cascade)

  @@index([userId, channelId])
  @@index([userId, directMessageGroupId])
  @@index([userId]) // For fetching all read receipts for a user
  @@index([channelId]) // For channel-specific queries
  @@index([directMessageGroupId]) // For DM-specific queries
}

model Notification {
  id                   String           @id @default(uuid())
  userId               String
  type                 NotificationType
  messageId            String?
  channelId            String?
  directMessageGroupId String?
  authorId             String // Who triggered the notification
  parentMessageId      String? // For thread reply notifications
  read                 Boolean          @default(false)
  dismissed            Boolean          @default(false)
  createdAt            DateTime         @default(now())

  user               User                @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  message            Message?            @relation(fields: [messageId], references: [id], onDelete: Cascade)
  author             User                @relation("NotificationAuthors", fields: [authorId], references: [id], onDelete: Cascade)
  channel            Channel?            @relation("ChannelNotifications", fields: [channelId], references: [id], onDelete: Cascade)
  parentMessage      Message?            @relation("NotificationParentMessage", fields: [parentMessageId], references: [id], onDelete: SetNull)
  directMessageGroup DirectMessageGroup? @relation("NotificationDMGroup", fields: [directMessageGroupId], references: [id], onDelete: Cascade)

  @@index([userId, read]) // Fast query for unread notifications
  @@index([userId, createdAt]) // For notification history with pagination
}

model UserNotificationSettings {
  id                  String   @id @default(uuid())
  userId              String   @unique
  desktopEnabled      Boolean  @default(true)
  playSound           Boolean  @default(true)
  soundType           String   @default("default") // "default", "mention", "dm"
  doNotDisturb        Boolean  @default(false)
  dndStartTime        String? // "22:00" - 24-hour format
  dndEndTime          String? // "08:00" - 24-hour format
  defaultChannelLevel String   @default("mentions") // 'all' | 'mentions' | 'none'
  dmNotifications     Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation("UserNotificationSettings", fields: [userId], references: [id], onDelete: Cascade)
}

model UserAppearanceSettings {
  id          String   @id @default(uuid())
  userId      String   @unique
  themeMode   String   @default("dark") // "dark" | "light"
  accentColor String   @default("blue") // "teal" | "purple" | "orange" | "blue"
  intensity   String   @default("minimal") // "minimal" | "balanced" | "vibrant"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation("UserAppearanceSettings", fields: [userId], references: [id], onDelete: Cascade)
}

model ChannelNotificationOverride {
  id        String   @id @default(uuid())
  userId    String
  channelId String
  level     String // 'all' | 'mentions' | 'none'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation("ChannelNotificationOverrides", fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation("ChannelNotificationOverrides", fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId]) // Fast lookup for user's overrides
}

model User {
  id             String       @id @default(uuid())
  username       String       @unique
  email          String?      @unique
  verified       Boolean      @default(false)
  hashedPassword String
  memberships    Membership[] @relation("UserMemberships")
  role           InstanceRole @default(USER)
  createdAt      DateTime     @default(now())
  avatarUrl      String?
  bannerUrl      String?
  lastSeen       DateTime?
  displayName    String?

  // Profile fields
  bio             String? // User biography/about text (max 500 chars)
  status          String? // Custom status message (max 128 chars)
  statusUpdatedAt DateTime? // When status was last updated

  // Storage quota (in bytes)
  storageQuotaBytes BigInt @default(53687091200) // 50GB default
  storageUsedBytes  BigInt @default(0) // Cached total usage

  // Blocking relations
  blockedUsers   UserBlock[] @relation("BlockerUser")
  blockedByUsers UserBlock[] @relation("BlockedUser")

  // Ban status
  banned      Boolean   @default(false)
  bannedAt    DateTime?
  bannedById  String?
  bannedBy    User?     @relation("BannedByUser", fields: [bannedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  bannedUsers User[]    @relation("BannedByUser")

  // Avatar/banner FK relations
  avatarFile File? @relation("UserAvatar", fields: [avatarUrl], references: [id], onDelete: SetNull)
  bannerFile File? @relation("UserBanner", fields: [bannerUrl], references: [id], onDelete: SetNull)

  InstanceInvite InstanceInvite[]

  UserRoles UserRoles[]

  RefreshToken RefreshToken[]

  directMessageGroupMemberships DirectMessageGroupMember[]
  friendshipsA                  Friendship[]               @relation("FriendshipA")
  friendshipsB                  Friendship[]               @relation("FriendshipB")

  ChannelMembership ChannelMembership[] @relation("UserChannelMemberships")
  File              File[]
  ReadReceipts      ReadReceipt[]       @relation("UserReadReceipts")

  // Notification relations
  notifications                Notification[]                @relation("UserNotifications")
  authoredNotifications        Notification[]                @relation("NotificationAuthors")
  notificationSettings         UserNotificationSettings?     @relation("UserNotificationSettings")
  channelNotificationOverrides ChannelNotificationOverride[] @relation("ChannelNotificationOverrides")

  // Appearance settings
  appearanceSettings UserAppearanceSettings? @relation("UserAppearanceSettings")

  // Replay buffer relations
  egressSessions EgressSession[]
  replayClips    ReplayClip[]

  // Push notification subscriptions
  pushSubscriptions PushSubscription[] @relation("UserPushSubscriptions")

  // Thread subscriptions
  threadSubscriptions ThreadSubscriber[] @relation("UserThreadSubscriptions")

  // Alias group memberships
  aliasGroupMemberships AliasGroupMember[]

  // FK back-references
  authoredMessages          Message[]             @relation("MessageAuthor")
  pinnedMessages            Message[]             @relation("MessagePinner")
  deletedMessages           Message[]             @relation("MessageDeleter")
  mentionSpans              MessageSpan[]         @relation("SpanUser")
  addedChannelMemberships   ChannelMembership[]   @relation("ChannelMembershipAddedBy")
  moderatorLogs             ModerationLog[]       @relation("LogModerator")
  targetOfLogs              ModerationLog[]       @relation("LogTargetUser")
  messageReactions          MessageReaction[]     @relation("ReactionUser")
  communityBansReceived     CommunityBan[]        @relation("BannedUser")
  communityBansMade         CommunityBan[]        @relation("BanModerator")
  communityTimeoutsReceived CommunityTimeout[]    @relation("TimedOutUser")
  communityTimeoutsMade     CommunityTimeout[]    @relation("TimeoutModerator")
  instanceInviteUsages      InstanceInviteUsage[] @relation("InviteUsageUser")
  resourceFiles             File[]                @relation("FileResourceUser")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])

  // Session/device tracking
  deviceName String? // User-friendly name (e.g., "Chrome on Windows")
  userAgent  String? // Full user agent string
  ipAddress  String? // Client IP address
  lastUsedAt DateTime @default(now()) // Last activity with this token

  // Token family for reuse detection (RFC 9700 best practice)
  // All tokens from a single login share a familyId. On rotation the old
  // token is marked consumed rather than deleted. If a consumed token is
  // presented again, the entire family is invalidated.
  familyId   String?
  consumed   Boolean   @default(false)
  consumedAt DateTime?

  @@index([userId, lastUsedAt]) // For fetching user's sessions sorted by activity
  @@index([familyId]) // For invalidating entire token family on reuse
}

model InstanceInvite {
  id          String    @id @default(uuid())
  code        String    @unique
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id])
  maxUses     Int?
  uses        Int       @default(0)
  validUntil  DateTime?
  createdAt   DateTime  @default(now())
  disabled    Boolean   @default(false)

  // Junction tables replacing embedded arrays
  usages             InstanceInviteUsage[]
  defaultCommunities InstanceInviteDefaultCommunity[]
}

model InstanceInviteUsage {
  id       String   @id @default(uuid())
  inviteId String
  userId   String
  usedAt   DateTime @default(now())

  invite InstanceInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  user   User           @relation("InviteUsageUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([inviteId, userId])
  @@index([inviteId])
}

model InstanceInviteDefaultCommunity {
  id          String @id @default(uuid())
  inviteId    String
  communityId String

  invite    InstanceInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  community Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([inviteId, communityId])
  @@index([inviteId])
}

model InstanceSettings {
  id               String           @id @default(uuid())
  name             String           @default("Kraken")
  description      String?
  registrationMode RegistrationMode @default(INVITE_ONLY)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Storage settings
  defaultStorageQuotaBytes BigInt @default(53687091200) // 50GB default for new users
  maxFileSizeBytes         BigInt @default(524288000) // 500MB max per file

  // VAPID keys for push notifications (auto-generated if not set via env vars)
  vapidPublicKey  String?
  vapidPrivateKey String?
  vapidSubject    String?
}

enum RegistrationMode {
  OPEN // Anyone can register
  INVITE_ONLY // Requires an invite code
  CLOSED // Registration disabled
}

model Membership {
  id          String    @id @default(uuid())
  user        User      @relation("UserMemberships", fields: [userId], references: [id])
  community   Community @relation("CommunityMemberships", fields: [communityId], references: [id])
  joinedAt    DateTime  @default(now())
  userId      String
  communityId String

  @@unique([userId, communityId])
}

model Community {
  id          String       @id @default(uuid())
  name        String
  memberships Membership[] @relation("CommunityMemberships")
  channels    Channel[]
  createdAt   DateTime     @default(now())
  avatar      String?
  banner      String?
  description String?
  UserRoles   UserRoles[]
  roles       Role[]

  // Avatar/banner FK relations
  avatarFile File? @relation("CommunityAvatar", fields: [avatar], references: [id], onDelete: SetNull)
  bannerFile File? @relation("CommunityBanner", fields: [banner], references: [id], onDelete: SetNull)

  // Moderation relations
  bans           CommunityBan[]     @relation("CommunityBans")
  timeouts       CommunityTimeout[] @relation("CommunityTimeouts")
  moderationLogs ModerationLog[]    @relation("ModerationLogs")

  // Instance invite defaults
  instanceInviteDefaults InstanceInviteDefaultCommunity[]

  // FK back-references
  mentionSpans  MessageSpan[] @relation("SpanCommunity")
  aliasGroups   AliasGroup[]  @relation("AliasGroupCommunity")
  resourceFiles File[]        @relation("FileResourceCommunity")

  @@unique([name])
}

model Channel {
  id                    String                        @id @default(uuid())
  name                  String
  communityId           String
  community             Community?                    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdAt             DateTime                      @default(now())
  type                  ChannelType                   @default(TEXT)
  position              Int                           @default(0)
  slowmodeSeconds       Int                           @default(0) // 0 = disabled, >0 = seconds between messages
  Message               Message[]
  ChannelMembership     ChannelMembership[]           @relation("ChannelMembership")
  isPrivate             Boolean                       @default(false)
  ReadReceipts          ReadReceipt[]                 @relation("ChannelReadReceipts")
  notificationOverrides ChannelNotificationOverride[] @relation("ChannelNotificationOverrides")
  notifications         Notification[]                @relation("ChannelNotifications")

  // FK back-references
  replayClips    ReplayClip[]    @relation("ReplayClipChannel")
  egressSessions EgressSession[] @relation("EgressSessionChannel")

  @@unique([communityId, name])
  @@index([communityId, type, position])
}

model ChannelMembership {
  id        String   @id @default(uuid())
  user      User     @relation("UserChannelMemberships", fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel  @relation("ChannelMembership", fields: [channelId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())
  userId    String
  channelId String
  addedBy   String? // Who added this user (for private channels)

  addedByUser User? @relation("ChannelMembershipAddedBy", fields: [addedBy], references: [id], onDelete: SetNull)

  @@unique([userId, channelId])
}

model AliasGroup {
  id          String             @id @default(uuid())
  name        String
  communityId String
  members     AliasGroupMember[]
  createdAt   DateTime           @default(now())

  community    Community     @relation("AliasGroupCommunity", fields: [communityId], references: [id], onDelete: Cascade)
  mentionSpans MessageSpan[] @relation("SpanAlias")

  @@unique([communityId, name])
}

model AliasGroupMember {
  id           String      @id @default(uuid())
  aliasGroupId String
  userId       String
  aliasGroup   AliasGroup? @relation(fields: [aliasGroupId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([aliasGroupId, userId])
}

model Role {
  id          String        @id @default(uuid())
  name        String
  communityId String?
  community   Community?    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  isDefault   Boolean       @default(false)
  actions     RbacActions[] @default([])
  createdAt   DateTime      @default(now())

  UserRoles UserRoles[]

  @@index([name, communityId])
}

model UserRoles {
  id             String     @id @default(uuid())
  // This is the same relationship as Membership, but it simplifies the auth lookup since our token only has the userId
  userId         String
  communityId    String?
  roleId         String
  isInstanceRole Boolean    @default(false)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  community      Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  role           Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([userId, communityId, roleId])
}

model DirectMessageGroup {
  id           String                     @id @default(uuid())
  name         String? // Optional, for group DMs
  members      DirectMessageGroupMember[]
  createdAt    DateTime                   @default(now())
  messages     Message[]                  @relation("DirectMessageGroupMessages")
  isGroup      Boolean                    @default(false) // true for group DMs, false for 1:1
  ReadReceipts ReadReceipt[]              @relation("DirectMessageGroupReadReceipts")

  // FK back-references
  notifications Notification[] @relation("NotificationDMGroup")
}

model DirectMessageGroupMember {
  id       String             @id @default(uuid())
  groupId  String
  userId   String
  group    DirectMessageGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime           @default(now())

  @@unique([groupId, userId])
  @@index([userId]) // For loading DM groups by user
}

model Friendship {
  id        String           @id @default(uuid())
  userAId   String
  userBId   String
  createdAt DateTime         @default(now())
  status    FriendshipStatus @default(PENDING)
  userA     User             @relation("FriendshipA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User             @relation("FriendshipB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userBId]) // For OR-clause friend lookup
}

model UserBlock {
  id        String   @id @default(uuid())
  blockerId String // User doing the blocking
  blockedId String // User being blocked
  createdAt DateTime @default(now())
  blocker   User     @relation("BlockerUser", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model File {
  id           String       @id @default(uuid())
  filename     String // Original filename
  mimeType     String // MIME type (image/jpeg, etc.)
  fileType     FileType // Enum for different file types
  size         Int // File size in bytes
  checksum     String // SHA-256 hash for integrity
  uploadedBy   User?        @relation(fields: [uploadedById], references: [id])
  uploadedById String?
  uploadedAt   DateTime     @default(now())
  deletedAt    DateTime? // Soft delete
  resourceType ResourceType

  // Typed FK columns (replaces polymorphic resourceId)
  fileUserId      String? // USER_AVATAR, USER_BANNER, REPLAY_CLIP
  fileCommunityId String? // COMMUNITY_AVATAR, COMMUNITY_BANNER, CUSTOM_EMOJI
  fileMessageId   String? // MESSAGE_ATTACHMENT

  // Storage configuration
  storageType   StorageType @default(LOCAL)
  storagePath   String // Local path or cloud key
  thumbnailPath String? // Path to generated thumbnail image (for videos)

  // Typed FK relations
  resourceUser      User?      @relation("FileResourceUser", fields: [fileUserId], references: [id], onDelete: Cascade)
  resourceCommunity Community? @relation("FileResourceCommunity", fields: [fileCommunityId], references: [id], onDelete: Cascade)
  resourceMessage   Message?   @relation("FileResourceMessage", fields: [fileMessageId], references: [id], onDelete: Cascade)

  // Relations
  replayClips        ReplayClip[]
  messageAttachments MessageAttachment[]

  // Avatar/banner back-references
  userAvatars      User[]      @relation("UserAvatar")
  userBanners      User[]      @relation("UserBanner")
  communityAvatars Community[] @relation("CommunityAvatar")
  communityBanners Community[] @relation("CommunityBanner")

  @@index([uploadedById]) // show my files or files for specific user
  @@index([deletedAt]) // For cleaning up deleted files
  @@index([fileUserId]) // For fetching files related to a user
  @@index([fileCommunityId]) // For fetching files related to a community
  @@index([fileMessageId]) // For fetching files related to a message
}

model EgressSession {
  id          String    @id @default(uuid())
  egressId    String    @unique // LiveKit egress ID
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomName    String // LiveKit room name (channel ID)
  channelId   String // Voice channel ID
  segmentPath String // Path to segments (for cleanup)
  status      String // "active", "stopped", "failed"
  error       String? // Error message if egress failed
  startedAt   DateTime
  endedAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  channel Channel @relation("EgressSessionChannel", fields: [channelId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
}

model ReplayClip {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileId          String
  file            File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  channelId       String? // Optional: which channel it was captured from
  durationSeconds Int // Duration of the clip in seconds
  isPublic        Boolean  @default(false) // Show on user's public profile
  capturedAt      DateTime @default(now())

  channel Channel? @relation("ReplayClipChannel", fields: [channelId], references: [id], onDelete: SetNull)

  @@index([userId, capturedAt])
}

model CommunityBan {
  id          String    @id @default(uuid())
  communityId String
  userId      String
  moderatorId String? // Nullable: SetNull when moderator is deleted
  reason      String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime? // null = permanent ban
  active      Boolean   @default(true)

  community Community @relation("CommunityBans", fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  moderator User?     @relation("BanModerator", fields: [moderatorId], references: [id], onDelete: SetNull)

  @@unique([communityId, userId])
  @@index([communityId, active])
}

model CommunityTimeout {
  id          String   @id @default(uuid())
  communityId String
  userId      String
  moderatorId String? // Nullable: SetNull when moderator is deleted
  reason      String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime // Required - timeouts are always temporary

  community Community @relation("CommunityTimeouts", fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation("TimedOutUser", fields: [userId], references: [id], onDelete: Cascade)
  moderator User?     @relation("TimeoutModerator", fields: [moderatorId], references: [id], onDelete: SetNull)

  @@unique([communityId, userId])
  @@index([communityId, expiresAt])
}

model ModerationLog {
  id              String           @id @default(uuid())
  communityId     String
  moderatorId     String? // Nullable: SetNull when moderator is deleted
  targetUserId    String?
  targetMessageId String?
  action          ModerationAction
  reason          String?
  metadata        Json?
  createdAt       DateTime         @default(now())

  community     Community @relation("ModerationLogs", fields: [communityId], references: [id], onDelete: Cascade)
  moderator     User?     @relation("LogModerator", fields: [moderatorId], references: [id], onDelete: SetNull)
  targetUser    User?     @relation("LogTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetMessage Message?  @relation("LogTargetMessage", fields: [targetMessageId], references: [id], onDelete: SetNull)

  @@index([communityId, createdAt])
}

